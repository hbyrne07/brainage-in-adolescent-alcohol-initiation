# Custom function to read a TSV file and filter to baseline data immediately
read_and_filter_baseline <- function(file_path) {
  
  data <- read.delim(file_path, sep = "\t", header = TRUE)
  
  if ("session_id" %in% colnames(data)) {
    data <- data %>%
      filter(session_id == "ses-00A")  # Replace blank with the baseline session id from data dictionary
  } else {
    warning(paste("No 'session' column in", file_path, "- no baseline filtering applied.")) # this will tell us if any errors
  }

  return(data)}

